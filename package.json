{
  "name": "automated",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest --coverage",
    "coverage": "c8 --reporter=html --reporter=text npm test",
    "lint": "eslint .",
    "lint:fix": "eslint --fix",
    "lint-staged": "lint-staged --quiet",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.js": [
			"eslint --fix"
		],
    "*.{ts,tsx,js,json}": [
      "eslint --fix"
    ]
  },
 
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@babel/preset-env": "^7.27.1",
    "babel-jest": "^29.7.0",
    "c8": "^10.1.3",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-jest": "^28.11.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-html-reporter": "^4.1.0",
    "jest-html-reporters": "^3.1.7",
    "jest-junit": "^16.0.0",
    "lint-staged": "^15.0.0",
    "vite": "^6.2.0"
  }
}
